   "source": [
    "print(\"Max length is: \",max(review_lengths))\n",
    "print(\"90th percentile: \",np.percentile(review_lengths,90))\n",
    "print(\"99.5th percentile: \",np.percentile(review_lengths,99.5))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2159f076-bd26-4d90-8122-ee75e49532b7",
   "metadata": {},
   "source": [
